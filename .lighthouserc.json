{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "startServerCommand": "python -m http.server 8000",
      "url": [
        "http://localhost:8000",
        "http://localhost:8000/#quickstart",
        "http://localhost:8000/#apis",
        "http://localhost:8000/#playground"
      ],
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance": ["error", {"minScore": 0.9}],
        "categories:accessibility": ["error", {"minScore": 0.95}],
        "categories:best-practices": ["error", {"minScore": 0.95}],
        "categories:seo": ["error", {"minScore": 0.95}],
        "categories:pwa": ["warn", {"minScore": 0.8}],

        "first-contentful-paint": ["error", {"maxNumericValue": 2000}],
        "largest-contentful-paint": ["error", {"maxNumericValue": 2500}],
        "cumulative-layout-shift": ["error", {"maxNumericValue": 0.1}],
        "total-blocking-time": ["error", {"maxNumericValue": 300}],
        "speed-index": ["error", {"maxNumericValue": 3000}],

        "uses-responsive-images": "off",
        "offscreen-images": "off",
        "uses-http2": "off",
        "uses-long-cache-ttl": "warn",
        "unminified-css": "warn",
        "unminified-javascript": "warn",
        "unused-css-rules": "warn",
        "unused-javascript": "warn",

        "color-contrast": ["error", {"minScore": 1}],
        "aria-valid-attr": ["error", {"minScore": 1}],
        "button-name": ["error", {"minScore": 1}],
        "bypass": ["error", {"minScore": 1}],
        "document-title": ["error", {"minScore": 1}],
        "duplicate-id-aria": ["error", {"minScore": 1}],
        "html-has-lang": ["error", {"minScore": 1}],
        "image-alt": ["error", {"minScore": 1}],
        "label": ["error", {"minScore": 1}],
        "link-name": ["error", {"minScore": 1}],
        "meta-viewport": ["error", {"minScore": 1}]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
